{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:products": "nest build products-service",
    "build:categories": "nest build categories-service",
    "build:orders": "nest build orders-service",
    "build:cart": "nest build cart-service",
    "build:gateway": "nest build api-gateway",
    "build:payments": "nest build payments-service",
    "build:notifications": "nest build notifications-service",
    "typeorm": "typeorm-ts-node-commonjs -d typeorm.data-source.ts",
    "migration:run": "npm.cmd run typeorm -- migration:run",
    "migration:revert": "npm.cmd run typeorm -- migration:revert",
    "migration:show": "npm.cmd run typeorm -- migration:show",
    "migration:generate": "npm.cmd run typeorm -- migration:generate",
    "format": "prettier --write \"src*/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:auth-users": "nest start auth-users-service",
    "start:auth-users:dev": "nest start auth-users-service --watch",
    "start:products": "nest start products-service",
    "start:products:dev": "nest start products-service --watch",
    "start:categories": "nest start categories-service",
    "start:categories:dev": "nest start categories-service --watch",
    "start:orders": "nest start orders-service",
    "start:orders:dev": "nest start orders-service --watch",
    "start:cart": "nest start cart-service",
    "start:cart:dev": "nest start cart-service --watch",
    "start:gateway": "nest start api-gateway",
    "start:gateway:dev": "nest start api-gateway --watch",
    "start:payments": "nest start payments-service",
    "start:payments:dev": "nest start payments-service --watch",
    "start:notifications": "nest start notifications-service",
    "start:notifications:dev": "nest start notifications-service --watch",
    "stop:all:dev": "node scripts/stop-backend-ports.js",
    "start:all:dev": "node scripts/start-all-backend.js",
    "restart:all:dev": "node scripts/start-all-backend.js --kill-existing",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src*,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.8",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.1.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src-auth-users",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
