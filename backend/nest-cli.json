{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src-auth-users",
  "monorepo": true,
  "root": "src-auth-users",
  "projects": {
    "auth-users-service": {
      "type": "application",
      "root": "src-auth-users",
      "entryFile": "main",
      "sourceRoot": "src-auth-users",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "products-service": {
      "type": "application",
      "root": "src-products",
      "entryFile": "main",
      "sourceRoot": "src-products/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "categories-service": {
      "type": "application",
      "root": "src-categories",
      "entryFile": "main",
      "sourceRoot": "src-categories/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "orders-service": {
      "type": "application",
      "root": "src-orders",
      "entryFile": "main",
      "sourceRoot": "src-orders/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "cart-service": {
      "type": "application",
      "root": "src-cart",
      "entryFile": "main",
      "sourceRoot": "src-cart/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "api-gateway": {
      "type": "application",
      "root": "src-gateway",
      "entryFile": "main",
      "sourceRoot": "src-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "payments-service": {
      "type": "application",
      "root": "src-payments",
      "entryFile": "main",
      "sourceRoot": "src-payments/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "notifications-service": {
      "type": "application",
      "root": "src-notifications",
      "entryFile": "main",
      "sourceRoot": "src-notifications/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    }
  },
  "compilerOptions": {
    "deleteOutDir": false
  }
}
